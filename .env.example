# -----------------------------------------------------------------------------
# Telegram bot credentials
# Paste your real Telegram bot token and the Telegram user ID of the admin who
# should have marketplace/admin access.
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
ADMIN_TELEGRAM_ID=your-admin-telegram-id-here

# -----------------------------------------------------------------------------
# Database connection
# Current runtime note:
# This app still uses MongoDB/Mongoose in production. If you want it to boot
# today, provide MONGODB_URI. DATABASE_URL can still be stored here for a future
# PostgreSQL/Neon migration, but it is not the active persistence backend yet.
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017/support

# -----------------------------------------------------------------------------
# Future PostgreSQL / Neon connection
# Paste your Neon Serverless PostgreSQL connection string here if you want to
# keep it available in env for a future migration.
# Example format:
# postgres://username:password@your-neon-host.neon.tech/dbname?sslmode=require
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://username:password@your-neon-host.neon.tech/dbname?sslmode=require

# -----------------------------------------------------------------------------
# EVM wallet receiving address
# Paste the wallet address that should receive on-chain EVM funds or payouts.
# -----------------------------------------------------------------------------
MY_EVM_RECEIVING_ADDRESS=0xYourEvmReceivingAddressHere

# -----------------------------------------------------------------------------
# Marketplace defaults
# Default lead unlock fee in EUR.
# -----------------------------------------------------------------------------
DEFAULT_LEAD_FEE_EUR=0.50

# -----------------------------------------------------------------------------
# Mini App / web deploy URL
# Use the public HTTPS URL of the running web service.
# If your hosting platform already exposes PUBLIC_URL automatically, you can use
# that instead of WEB_APP_URL.
# -----------------------------------------------------------------------------
WEB_APP_URL=https://your-public-app.example.com
PUBLIC_URL=
